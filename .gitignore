# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local database (WAL/SHM are runtime files, not committed)
local.db-shm
local.db-wal

# worktrees
.worktrees/
.superpowers/

# NetDragon original PNG masters (母版 — 保留本地,避免仓库膨胀)
# WebP 派生文件入 git,PNG 不入
/public/netdragon/**/*.png
